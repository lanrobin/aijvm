{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug aijvm",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/aijvm",
            "args": ["--bj", "/usr/lib/jvm/java-25-openjdk-amd64/jmods", "--cp", "${workspaceFolder}/tests/javaclasses", "-Xmx64M", "GCTest"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build-debug"
        }
    ]
}
